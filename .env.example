# App URL (no trailing slash)
BASE_URL=https://your-app-preview.vercel.app

# Vercel — protected preview access (vercel.com account, NOT the IDEA app account)
DEPLOYMENT_AUTH_USER=
DEPLOYMENT_AUTH_PASSWORD=

# Optional: bypass token (not needed if you have login/password above)
# VERCEL_PROTECTION_BYPASS=

# IDEA — login in the app itself (after passing Vercel protection)
TEST_USER=
TEST_PASSWORD=

# UI copy — adjust to match your app (defaults suit the anonymized showcase)
# APP_WELCOME_TEXT=Welcome to IDEA
# APP_HOME_TITLE=IDEA - Example application

# IDEA: auth uses modals on the home page (not /login or /signup — those may 404)
LOGIN_PATH=/
SIGNUP_PATH=/
RESET_PASSWORD_PATH=/

# LOGIN_EMAIL_LABEL=Enter your email
# LOGIN_PASSWORD_LABEL=Enter password
# LOGIN_ENTRY_BUTTON_NAME=Log in
# LOGIN_BUTTON_NAME=Continue
# SIGNUP_ENTRY_BUTTON_NAME=Get started
# SIGNUP_SUBMIT_NAME=Continue
# AGE_CONSENT_LABEL=age
# TERMS_CONSENT_LABEL=terms
# TERMS_LINK_NAME=Terms
# TERMS_OF_SERVICE_LINK_NAME=Terms of Service
# PRIVACY_POLICY_LINK_NAME=Privacy policy
# TERMS_OF_SERVICE_TITLE=Terms of Service
# PRIVACY_POLICY_TITLE=Privacy policy
# PAYWALL_HEADING=subscription|paywall|plan|premium
# SIGNUP_EMAIL_DOMAIN=example.com
